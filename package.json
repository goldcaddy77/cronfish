{
  "name": "cronfish",
  "version": "0.11.0",
  "description": "Drop a file. Cronfish does the rest. Markdown is a valid cron job.",
  "type": "module",
  "bin": {
    "cronfish": "./src/cli.ts"
  },
  "engines": {
    "bun": ">=1.0"
  },
  "scripts": {
    "test": "bun test",
    "build:ui": "cd ui && bun install && bun run build"
  },
  "files": [
    "src",
    "templates",
    "examples",
    "ui/dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cron",
    "scheduler",
    "launchd",
    "macos",
    "bun",
    "automation",
    "claude",
    "task-scheduler"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goldcaddy77/cronfish.git"
  },
  "homepage": "https://github.com/goldcaddy77/cronfish#readme",
  "bugs": {
    "url": "https://github.com/goldcaddy77/cronfish/issues"
  },
  "license": "MIT",
